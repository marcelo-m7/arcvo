APP_ENV=development
APP_NAME=Odoo FastAPI Template
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin@example.com
ODOO_API_KEY=replace-with-your-odoo-api-key
ODOO_ALLOW_SELF_SIGNED_SSL=false

# Coolify normally injects these values for Docker Compose.
SERVICE_FQDN_ODOO_8069=https://odoo.example.com
SERVICE_USER_POSTGRES=odoo
SERVICE_PASSWORD_POSTGRES=change-me-postgres-password
