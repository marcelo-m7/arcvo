<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Development Capabilities -->
        <record id="capability_backend_dev" model="agent.capability">
            <field name="name">backend_dev</field>
            <field name="category">development</field>
            <field name="description">Backend development with Python, FastAPI, databases, APIs</field>
        </record>

        <record id="capability_frontend_dev" model="agent.capability">
            <field name="name">frontend_dev</field>
            <field name="category">development</field>
            <field name="description">Frontend development with React, TypeScript, UI/UX</field>
        </record>

        <record id="capability_odoo_dev" model="agent.capability">
            <field name="name">odoo_dev</field>
            <field name="category">development</field>
            <field name="description">Odoo addon development, customization, XML-RPC integration</field>
        </record>

        <!-- Infrastructure Capabilities -->
        <record id="capability_devops" model="agent.capability">
            <field name="name">devops</field>
            <field name="category">infrastructure</field>
            <field name="description">DevOps, Docker, Kubernetes, CI/CD, deployment automation</field>
        </record>

        <record id="capability_database_admin" model="agent.capability">
            <field name="name">database_admin</field>
            <field name="category">infrastructure</field>
            <field name="description">Database administration, PostgreSQL, migrations, optimization</field>
        </record>

        <!-- Management Capabilities -->
        <record id="capability_project_management" model="agent.capability">
            <field name="name">project_management</field>
            <field name="category">management</field>
            <field name="description">Project planning, task coordination, team leadership</field>
        </record>

        <record id="capability_product_management" model="agent.capability">
            <field name="name">product_management</field>
            <field name="category">management</field>
            <field name="description">Product strategy, roadmapping, requirement gathering</field>
        </record>

        <!-- QA Capabilities -->
        <record id="capability_qa_testing" model="agent.capability">
            <field name="name">qa_testing</field>
            <field name="category">qa</field>
            <field name="description">QA testing, test automation, bug validation</field>
        </record>

        <record id="capability_code_review" model="agent.capability">
            <field name="name">code_review</field>
            <field name="category">qa</field>
            <field name="description">Code review, static analysis, security audit</field>
        </record>

        <!-- Documentation Capabilities -->
        <record id="capability_documentation" model="agent.capability">
            <field name="name">documentation</field>
            <field name="category">documentation</field>
            <field name="description">Documentation writing, knowledge base management, wikis</field>
        </record>

        <record id="capability_technical_writing" model="agent.capability">
            <field name="name">technical_writing</field>
            <field name="category">documentation</field>
            <field name="description">Technical documentation, API docs, architecture records</field>
        </record>
    </data>
</odoo>
