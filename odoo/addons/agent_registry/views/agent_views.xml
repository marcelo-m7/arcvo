<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Agent List View -->
        <record id="agent_agent_view_tree" model="ir.ui.view">
            <field name="name">agent.agent.tree</field>
            <field name="model">agent.agent</field>
            <field name="arch" type="xml">
                <list string="Agents" decoration-danger="status == 'error'" decoration-warning="status == 'offline'" decoration-success="is_available">
                    <field name="name"/>
                    <field name="agent_type"/>
                    <field name="status"/>
                    <field name="current_workload"/>
                    <field name="max_concurrent_tasks"/>
                    <field name="last_heartbeat"/>
                </list>
            </field>
        </record>

        <!-- Agent Form View -->
        <record id="agent_agent_view_form" model="ir.ui.view">
            <field name="name">agent.agent.form</field>
            <field name="model">agent.agent</field>
            <field name="arch" type="xml">
                <form string="Agent">
                    <header>
                        <button name="update_heartbeat" string="Update Heartbeat" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="agent_type"/>
                                <field name="status" widget="selection"/>
                                <field name="is_available" readonly="1" force_save="1"/>
                            </group>
                            <group>
                                <field name="current_workload" readonly="1"/>
                                <field name="max_concurrent_tasks"/>
                                <field name="last_heartbeat" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="description" nolabel="1" placeholder="Agent description..."/>
                        </group>
                        <group string="Capabilities">
                            <field name="capabilities_ids" nolabel="1" widget="many2many_tags"/>
                        </group>
                        <group string="API Access" groups="base.group_system">
                            <field name="api_key" readonly="1"/>
                            <field name="api_key_generated" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Assignments">
                                <field name="assignment_ids" readonly="1">
                                    <list>
                                        <field name="task_id"/>
                                        <field name="status"/>
                                        <field name="assigned_at"/>
                                        <field name="started_at"/>
                                        <field name="completed_at"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <field name="audit_log_ids" readonly="1">
                                    <list>
                                        <field name="action_type"/>
                                        <field name="task_id"/>
                                        <field name="timestamp"/>
                                        <field name="status_code"/>
                                        <field name="error_msg"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Agent Search View -->
        <record id="agent_agent_view_search" model="ir.ui.view">
            <field name="name">agent.agent.search</field>
            <field name="model">agent.agent</field>
            <field name="arch" type="xml">
                <search string="Search Agents">
                    <field name="name"/>
                    <field name="agent_type"/>
                    <field name="status"/>
                    <filter name="filter_online" string="Online" domain="[('status', 'in', ['available', 'busy'])]"/>
                    <filter name="filter_offline" string="Offline" domain="[('status', '=', 'offline')]"/>
                    <filter name="filter_error" string="Error" domain="[('status', '=', 'error')]"/>
                    <separator/>
                    <filter name="filter_orchestrator" string="Orchestrators" domain="[('agent_type', '=', 'orchestrator')]"/>
                    <filter name="filter_executor" string="Executors" domain="[('agent_type', '=', 'executor')]"/>
                    <filter name="filter_reviewer" string="Reviewers" domain="[('agent_type', '=', 'reviewer')]"/>
                </search>
            </field>
        </record>

        <!-- Agent Action -->
        <record id="agent_agent_action" model="ir.actions.act_window">
            <field name="name">Agents</field>
            <field name="res_model">agent.agent</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
