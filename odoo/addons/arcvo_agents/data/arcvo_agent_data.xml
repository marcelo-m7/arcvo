<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="capability_coordination" model="arcvo.agent.capability">
        <field name="name">coordination</field>
        <field name="category">strategy</field>
        <field name="description">Prioritizacao, delegacao e decisao operacional.</field>
    </record>
    <record id="capability_odoo" model="arcvo.agent.capability">
        <field name="name">odoo_operations</field>
        <field name="category">odoo</field>
        <field name="description">Projetos, tarefas, eLearning, modelos e dados Odoo.</field>
    </record>
    <record id="capability_backend" model="arcvo.agent.capability">
        <field name="name">backend_automation</field>
        <field name="category">backend</field>
        <field name="description">FastAPI, integracoes, scripts e automacoes controladas.</field>
    </record>
    <record id="capability_frontend" model="arcvo.agent.capability">
        <field name="name">hermes_operations</field>
        <field name="category">frontend</field>
        <field name="description">Hermes puro, ferramentas operacionais e experiencia de comando.</field>
    </record>
    <record id="capability_data_archive" model="arcvo.agent.capability">
        <field name="name">data_archive</field>
        <field name="category">data</field>
        <field name="description">Acervo, YouTube, Supabase, categorias e enriquecimento.</field>
    </record>
    <record id="capability_qa_deploy" model="arcvo.agent.capability">
        <field name="name">qa_deploy</field>
        <field name="category">qa</field>
        <field name="description">Validacao, qualidade, deploy e monitoramento Coolify.</field>
    </record>

    <record id="agent_ceo" model="arcvo.agent">
        <field name="name">Mona CEO</field>
        <field name="role">ceo</field>
        <field name="state">idle</field>
        <field name="description">Coordena prioridades e delega trabalho para a operacao Arcvo.</field>
        <field name="capability_ids" eval="[(6, 0, [ref('capability_coordination'), ref('capability_qa_deploy')])]"/>
    </record>
    <record id="agent_odoo" model="arcvo.agent">
        <field name="name">Odoo Specialist</field>
        <field name="role">odoo</field>
        <field name="state">idle</field>
        <field name="description">Cuida dos modelos, tarefas, eLearning e consistencia do Odoo 19.</field>
        <field name="capability_ids" eval="[(6, 0, [ref('capability_odoo'), ref('capability_coordination')])]"/>
    </record>
    <record id="agent_backend" model="arcvo.agent">
        <field name="name">Backend Operator</field>
        <field name="role">backend</field>
        <field name="state">idle</field>
        <field name="description">Executa automacoes controladas no FastAPI e nas integracoes.</field>
        <field name="capability_ids" eval="[(6, 0, [ref('capability_backend'), ref('capability_qa_deploy')])]"/>
    </record>
    <record id="agent_frontend" model="arcvo.agent">
        <field name="name">Frontend Maintainer</field>
        <field name="role">frontend</field>
        <field name="state">idle</field>
        <field name="description">Mantem a experiencia operacional no Hermes puro, sem frontend React ativo.</field>
        <field name="capability_ids" eval="[(6, 0, [ref('capability_frontend')])]"/>
    </record>
    <record id="agent_data" model="arcvo.agent">
        <field name="name">Acervo Curator</field>
        <field name="role">data</field>
        <field name="state">idle</field>
        <field name="description">Organiza videos, cursos, categorias e importacoes do acervo.</field>
        <field name="capability_ids" eval="[(6, 0, [ref('capability_data_archive'), ref('capability_odoo')])]"/>
    </record>
    <record id="agent_qa" model="arcvo.agent">
        <field name="name">QA Deploy</field>
        <field name="role">qa</field>
        <field name="state">idle</field>
        <field name="description">Valida checks, acompanha deploy e registra problemas de producao.</field>
        <field name="capability_ids" eval="[(6, 0, [ref('capability_qa_deploy'), ref('capability_backend')])]"/>
    </record>
</odoo>
