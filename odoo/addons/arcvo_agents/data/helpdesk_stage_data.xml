<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="arcvo_helpdesk_stage_new" model="arcvo.helpdesk.stage">
        <field name="name">New</field>
        <field name="code">new</field>
        <field name="sequence">10</field>
    </record>
    <record id="arcvo_helpdesk_stage_in_progress" model="arcvo.helpdesk.stage">
        <field name="name">In Progress</field>
        <field name="code">in_progress</field>
        <field name="sequence">20</field>
    </record>
    <record id="arcvo_helpdesk_stage_blocked" model="arcvo.helpdesk.stage">
        <field name="name">Blocked</field>
        <field name="code">blocked</field>
        <field name="sequence">30</field>
    </record>
    <record id="arcvo_helpdesk_stage_resolved" model="arcvo.helpdesk.stage">
        <field name="name">Resolved</field>
        <field name="code">resolved</field>
        <field name="sequence">40</field>
        <field name="is_closed">True</field>
    </record>
    <record id="arcvo_helpdesk_stage_closed" model="arcvo.helpdesk.stage">
        <field name="name">Closed</field>
        <field name="code">closed</field>
        <field name="sequence">50</field>
        <field name="fold">True</field>
        <field name="is_closed">True</field>
    </record>
</odoo>
