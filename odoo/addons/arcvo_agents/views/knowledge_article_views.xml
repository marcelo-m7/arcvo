<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_arcvo_knowledge_article_search" model="ir.ui.view">
        <field name="name">arcvo.knowledge.article.search</field>
        <field name="model">arcvo.knowledge.article</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="article_ref"/>
                <field name="state"/>
                <field name="category_id"/>
                <field name="owner_agent_id"/>
                <filter string="Published" domain="[('state','=','published')]"/>
                <filter string="Draft" domain="[('state','=','draft')]"/>
                <group expand="0" string="Group By">
                    <filter string="State" context="{'group_by':'state'}"/>
                    <filter string="Category" context="{'group_by':'category_id'}"/>
                    <filter string="Owner" context="{'group_by':'owner_agent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_arcvo_knowledge_article_list" model="ir.ui.view">
        <field name="name">arcvo.knowledge.article.list</field>
        <field name="model">arcvo.knowledge.article</field>
        <field name="arch" type="xml">
            <list>
                <field name="article_ref"/>
                <field name="name"/>
                <field name="state"/>
                <field name="category_id"/>
                <field name="owner_agent_id"/>
                <field name="version"/>
                <field name="published_at"/>
            </list>
        </field>
    </record>

    <record id="view_arcvo_knowledge_article_kanban" model="ir.ui.view">
        <field name="name">arcvo.knowledge.article.kanban</field>
        <field name="model">arcvo.knowledge.article</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="article_ref"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="owner_agent_id"/>
                <field name="version"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_title">
                            <strong><field name="article_ref"/> - <field name="name"/></strong>
                        </div>
                        <div>
                            Category: <field name="category_id"/>
                        </div>
                        <div>
                            Owner: <field name="owner_agent_id"/>
                        </div>
                        <div>
                            Version: <field name="version"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_arcvo_knowledge_article_form" model="ir.ui.view">
        <field name="name">arcvo.knowledge.article.form</field>
        <field name="model">arcvo.knowledge.article</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_review" type="object" string="Submit Review"/>
                    <button name="action_publish" type="object" string="Publish" class="btn-primary"/>
                    <button name="action_archive" type="object" string="Archive"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="article_ref" readonly="1"/>
                            <field name="name"/>
                            <field name="slug" readonly="1"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="owner_agent_id"/>
                            <field name="task_id"/>
                            <field name="version" readonly="1"/>
                            <field name="published_at" readonly="1"/>
                        </group>
                    </group>
                    <field name="summary"/>
                    <field name="tags"/>
                    <field name="related_ticket_ids" widget="many2many_tags"/>
                    <field name="content_html"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_arcvo_knowledge_articles" model="ir.actions.act_window">
        <field name="name">Knowledge Articles</field>
        <field name="res_model">arcvo.knowledge.article</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_arcvo_knowledge_article_search"/>
    </record>

    <menuitem id="menu_arcvo_knowledge_root" name="Knowledge" parent="menu_arcvo_root" sequence="30"/>
    <menuitem id="menu_arcvo_knowledge_articles" name="Articles" parent="menu_arcvo_knowledge_root" action="action_arcvo_knowledge_articles" sequence="10"/>
    <menuitem id="menu_arcvo_knowledge_categories" name="Categories" parent="menu_arcvo_knowledge_root" action="action_arcvo_knowledge_categories" sequence="20"/>
</odoo>
