<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- arcvo.automation.webhook Tree View -->
        <record id="arcvo_automation_webhook_tree" model="ir.ui.view">
            <field name="name">Automation Webhooks - Tree</field>
            <field name="model">arcvo.automation.webhook</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence" widget="handle" />
                    <field name="name" />
                    <field name="trigger" />
                    <field name="action" />
                    <field name="active" widget="boolean" />
                    <field name="execution_count" />
                    <field name="last_execution" />
                </list>
            </field>
        </record>

        <!-- arcvo.automation.webhook Form View -->
        <record id="arcvo_automation_webhook_form" model="ir.ui.view">
            <field name="name">Automation Webhooks - Form</field>
            <field name="model">arcvo.automation.webhook</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="active" widget="boolean_toggle" />
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" />
                                <field name="sequence" />
                                <field name="trigger" />
                                <field name="action" />
                            </group>
                            <group>
                                <field name="execution_count" />
                                <field name="last_execution" />
                            </group>
                        </group>

                        <separator string="Domain Filter" />
                        <p class="text-muted">
                            Optional: Enter a domain filter (JSON array) to limit when this webhook fires.
                            Example: [["project_id", "=", 5], ["arcvo_requires_agent", "=", true]]
                            Leave empty to apply to all tasks.
                        </p>
                        <field name="domain" />

                        <separator string="Error Information" />
                        <field name="last_error" nolabel="1" />

                        <separator string="Notes" />
                        <field name="notes" nolabel="1" />
                    </sheet>
                </form>
            </field>
        </record>

        <!-- arcvo.automation.webhook Search View -->
        <record id="arcvo_automation_webhook_search" model="ir.ui.view">
            <field name="name">Automation Webhooks - Search</field>
            <field name="model">arcvo.automation.webhook</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" />
                    <field name="trigger" />
                    <field name="action" />
                    <separator />
                    <filter name="active" string="Active" domain="[('active', '=', True)]" />
                    <filter name="inactive" string="Inactive" domain="[('active', '=', False)]" />
                    <separator />
                    <filter name="on_create" string="On Task Created" domain="[('trigger', '=', 'task.created')]" />
                    <filter name="on_change" string="On State Change" domain="[('trigger', '=', 'task.state_change')]" />
                    <filter name="on_write" string="On Task Updated" domain="[('trigger', '=', 'task.write')]" />
                </search>
            </field>
        </record>

        <!-- Action to view webhooks -->
        <record id="arcvo_automation_webhook_action" model="ir.actions.act_window">
            <field name="name">Automation Webhooks</field>
            <field name="res_model">arcvo.automation.webhook</field>
            <field name="view_mode">list,form</field>
            <field name="help">Configure event triggers for automatic agent execution (webhooks).
Each webhook can fire on task creation, state change, or update, and trigger agent execution or other actions.</field>
        </record>

        <!-- Menu item -->
        <menuitem
            id="menu_arcvo_automation_webhook"
            name="Webhooks"
            parent="menu_arcvo_root"
            action="arcvo_automation_webhook_action"
            sequence="40"
        />

        <!-- ========== Automation Log Views ========== -->

        <!-- arcvo.automation.log Tree View -->
        <record id="arcvo_automation_log_tree" model="ir.ui.view">
            <field name="name">Automation Logs - Tree</field>
            <field name="model">arcvo.automation.log</field>
            <field name="arch" type="xml">
                <list create="0" edit="0">
                    <field name="create_date" />
                    <field name="webhook_id" />
                    <field name="task_id" />
                    <field name="action" />
                    <field name="result" decoration-success="result=='success'" decoration-danger="result=='error'" />
                    <field name="message" />
                </list>
            </field>
        </record>

        <!-- arcvo.automation.log Form View -->
        <record id="arcvo_automation_log_form" model="ir.ui.view">
            <field name="name">Automation Logs - Form</field>
            <field name="model">arcvo.automation.log</field>
            <field name="arch" type="xml">
                <form create="0" edit="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="create_date" />
                                <field name="webhook_id" />
                                <field name="result" />
                            </group>
                            <group>
                                <field name="task_id" />
                                <field name="agent_id" />
                                <field name="action" />
                            </group>
                        </group>

                        <separator string="Details" />
                        <field name="message" nolabel="1" />
                    </sheet>
                </form>
            </field>
        </record>

        <!-- arcvo.automation.log Search View -->
        <record id="arcvo_automation_log_search" model="ir.ui.view">
            <field name="name">Automation Logs - Search</field>
            <field name="model">arcvo.automation.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="webhook_id" />
                    <field name="task_id" />
                    <field name="action" />
                    <separator />
                    <filter name="success" string="Success" domain="[('result', '=', 'success')]" />
                    <filter name="error" string="Error" domain="[('result', '=', 'error')]" />
                    <filter name="skipped" string="Skipped" domain="[('result', '=', 'skipped')]" />
                    <separator />
                </search>
            </field>
        </record>

        <!-- Action to view automation logs -->
        <record id="arcvo_automation_log_action" model="ir.actions.act_window">
            <field name="name">Automation Logs</field>
            <field name="res_model">arcvo.automation.log</field>
            <field name="view_mode">list,form</field>
            <field name="help">View execution logs for all automated webhooks. This is an immutable audit trail.</field>
        </record>

        <!-- Menu item -->
        <menuitem
            id="menu_arcvo_automation_log"
            name="Automation Logs"
            parent="menu_arcvo_root"
            action="arcvo_automation_log_action"
            sequence="41"
        />

    </data>
</odoo>
