<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_arcvo_helpdesk_ticket_search" model="ir.ui.view">
        <field name="name">arcvo.helpdesk.ticket.search</field>
        <field name="model">arcvo.helpdesk.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="ticket_ref"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="assignee_agent_id"/>
                <field name="task_id"/>
                <filter name="filter_open" string="Open" domain="[('state','not in',('resolved','closed'))]"/>
                <filter name="filter_sla_breached" string="SLA Breached" domain="[('sla_deadline','&lt;', context_today()), ('state','not in',('resolved','closed'))]"/>
                <filter name="filter_resolved" string="Resolved" domain="[('state','=','resolved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Stage" context="{'group_by':'stage_id'}"/>
                    <filter string="Agent" context="{'group_by':'assignee_agent_id'}"/>
                    <filter string="Priority" context="{'group_by':'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_arcvo_helpdesk_ticket_list" model="ir.ui.view">
        <field name="name">arcvo.helpdesk.ticket.list</field>
        <field name="model">arcvo.helpdesk.ticket</field>
        <field name="arch" type="xml">
            <list>
                <field name="ticket_ref"/>
                <field name="name"/>
                <field name="priority"/>
                <field name="stage_id"/>
                <field name="assignee_agent_id"/>
                <field name="task_id"/>
                <field name="sla_deadline"/>
                <field name="sla_breached"/>
                <field name="opened_at"/>
            </list>
        </field>
    </record>

    <record id="view_arcvo_helpdesk_ticket_kanban" model="ir.ui.view">
        <field name="name">arcvo.helpdesk.ticket.kanban</field>
        <field name="model">arcvo.helpdesk.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id">
                <field name="ticket_ref"/>
                <field name="name"/>
                <field name="priority"/>
                <field name="assignee_agent_id"/>
                <field name="sla_deadline"/>
                <field name="sla_breached"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_title">
                            <strong><field name="ticket_ref"/> - <field name="name"/></strong>
                        </div>
                        <div class="text-muted">
                            Priority: <field name="priority"/>
                        </div>
                        <div>
                            Agent: <field name="assignee_agent_id"/>
                        </div>
                        <div>
                            SLA: <field name="sla_deadline"/>
                        </div>
                        <div t-if="record.sla_breached.raw_value" class="text-danger">
                            SLA breached
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_arcvo_helpdesk_ticket_form" model="ir.ui.view">
        <field name="name">arcvo.helpdesk.ticket.form</field>
        <field name="model">arcvo.helpdesk.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_in_progress" type="object" string="Start" class="btn-primary"/>
                    <button name="action_set_blocked" type="object" string="Block"/>
                    <button name="action_set_resolved" type="object" string="Resolve"/>
                    <button name="action_set_closed" type="object" string="Close"/>
                    <button name="action_reopen" type="object" string="Reopen"/>
                    <button name="action_record_first_response" type="object" string="First Response"/>
                    <button name="action_assign_agent" type="object" string="Assign Agent"/>
                    <field name="stage_id" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="ticket_ref" readonly="1"/>
                            <field name="name"/>
                            <field name="priority"/>
                            <field name="requester_partner_id"/>
                        </group>
                        <group>
                            <field name="assignee_agent_id"/>
                            <field name="task_id"/>
                            <field name="assignment_id"/>
                            <field name="sla_deadline"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="opened_at" readonly="1"/>
                            <field name="first_response_at" readonly="1"/>
                            <field name="resolved_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="closed_at" readonly="1"/>
                            <field name="sla_breached" readonly="1"/>
                            <field name="response_time_hours" readonly="1"/>
                            <field name="resolution_time_hours" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Knowledge">
                            <field name="knowledge_article_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Comments">
                            <field name="comment_ids" readonly="1">
                                <list>
                                    <field name="created_at"/>
                                    <field name="author_id"/>
                                    <field name="comment_type"/>
                                    <field name="body"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_arcvo_helpdesk_tickets" model="ir.actions.act_window">
        <field name="name">Helpdesk Tickets</field>
        <field name="res_model">arcvo.helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_arcvo_helpdesk_ticket_search"/>
    </record>

    <menuitem id="menu_arcvo_helpdesk_root" name="Helpdesk" parent="menu_arcvo_root" sequence="20"/>
    <menuitem id="menu_arcvo_helpdesk_tickets" name="Tickets" parent="menu_arcvo_helpdesk_root" action="action_arcvo_helpdesk_tickets" sequence="10"/>
    <menuitem id="menu_arcvo_helpdesk_stages" name="Stages" parent="menu_arcvo_helpdesk_root" action="action_arcvo_helpdesk_stages" sequence="20"/>
</odoo>
