<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_arcvo_agent_capability_list" model="ir.ui.view">
        <field name="name">arcvo.agent.capability.list</field>
        <field name="model">arcvo.agent.capability</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_arcvo_agent_capability_form" model="ir.ui.view">
        <field name="name">arcvo.agent.capability.form</field>
        <field name="model">arcvo.agent.capability</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="active"/>
                    </group>
                    <field name="description"/>
                    <field name="agent_ids" widget="many2many_tags"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_arcvo_agent_capabilities" model="ir.actions.act_window">
        <field name="name">Capabilities</field>
        <field name="res_model">arcvo.agent.capability</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_arcvo_agent_capabilities" name="Capabilities" parent="menu_arcvo_root" action="action_arcvo_agent_capabilities"/>
</odoo>
