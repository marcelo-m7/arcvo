<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_arcvo_agent_audit_log_list" model="ir.ui.view">
        <field name="name">arcvo.agent.audit.log.list</field>
        <field name="model">arcvo.agent.audit.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="created_at"/>
                <field name="agent_id"/>
                <field name="task_id"/>
                <field name="action"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="action_arcvo_agent_audit_logs" model="ir.actions.act_window">
        <field name="name">Audit Logs</field>
        <field name="res_model">arcvo.agent.audit.log</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_arcvo_agent_audit_logs" name="Audit Logs" parent="menu_arcvo_root" action="action_arcvo_agent_audit_logs"/>
</odoo>
