<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_arcvo_agent_assignment_list" model="ir.ui.view">
        <field name="name">arcvo.agent.assignment.list</field>
        <field name="model">arcvo.agent.assignment</field>
        <field name="arch" type="xml">
            <list>
                <field name="task_id"/>
                <field name="agent_id"/>
                <field name="status"/>
                <field name="progress"/>
                <field name="assigned_at"/>
                <field name="completed_at"/>
            </list>
        </field>
    </record>

    <record id="view_arcvo_agent_assignment_form" model="ir.ui.view">
        <field name="name">arcvo.agent.assignment.form</field>
        <field name="model">arcvo.agent.assignment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" type="object" string="Start"/>
                    <button name="action_complete" type="object" string="Complete"/>
                    <button name="action_fail" type="object" string="Fail"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="task_id"/>
                        <field name="agent_id"/>
                        <field name="progress"/>
                    </group>
                    <group>
                        <field name="assigned_at"/>
                        <field name="started_at"/>
                        <field name="completed_at"/>
                    </group>
                    <field name="notes"/>
                    <field name="result"/>
                    <field name="error_message"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_arcvo_agent_assignments" model="ir.actions.act_window">
        <field name="name">Assignments</field>
        <field name="res_model">arcvo.agent.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_arcvo_agent_assignments" name="Assignments" parent="menu_arcvo_root" action="action_arcvo_agent_assignments"/>
</odoo>
