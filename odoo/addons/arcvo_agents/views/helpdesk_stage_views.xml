<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_arcvo_helpdesk_stage_list" model="ir.ui.view">
        <field name="name">arcvo.helpdesk.stage.list</field>
        <field name="model">arcvo.helpdesk.stage</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_closed"/>
                <field name="fold"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_arcvo_helpdesk_stage_form" model="ir.ui.view">
        <field name="name">arcvo.helpdesk.stage.form</field>
        <field name="model">arcvo.helpdesk.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="is_closed"/>
                            <field name="fold"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_arcvo_helpdesk_stages" model="ir.actions.act_window">
        <field name="name">Helpdesk Stages</field>
        <field name="res_model">arcvo.helpdesk.stage</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
