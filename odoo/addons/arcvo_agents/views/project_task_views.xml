<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form_arcvo_agents" model="ir.ui.view">
        <field name="name">project.task.form.arcvo.agents</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//notebook" position="inside">
                <page string="Arcvo">
                    <group>
                        <field name="arcvo_requires_agent"/>
                        <field name="arcvo_agent_id"/>
                    </group>
                    <field name="arcvo_assignment_ids"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
