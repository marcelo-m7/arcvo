<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- arcvo.automation.matcher Tree View -->
        <record id="arcvo_automation_matcher_tree" model="ir.ui.view">
            <field name="name">Automation Matcher - Tree</field>
            <field name="model">arcvo.automation.matcher</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence" widget="handle" />
                    <field name="name" />
                    <field name="match_type" />
                    <field name="assignment_strategy" />
                    <field name="active" widget="boolean" />
                    <field name="assignment_count" />
                    <field name="last_assignment" />
                </list>
            </field>
        </record>

        <!-- arcvo.automation.matcher Form View -->
        <record id="arcvo_automation_matcher_form" model="ir.ui.view">
            <field name="name">Automation Matcher - Form</field>
            <field name="model">arcvo.automation.matcher</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="active" widget="boolean_toggle" />
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" />
                                <field name="sequence" />
                                <field name="match_type" />
                            </group>
                            <group>
                                <field name="assignment_count" />
                                <field name="last_assignment" />
                            </group>
                        </group>

                        <!-- Match Type: Tag -->
                        <group invisible="match_type != 'tag'">
                            <separator string="Tag-Based Matching" colspan="2" />
                            <field name="task_tag_ids" widget="many2many_tags" colspan="2" />
                            <p class="text-muted" colspan="2">
                                Tasks with ANY of these tags will match this rule.
                            </p>
                        </group>

                        <!-- Match Type: Keyword -->
                        <group invisible="match_type != 'keyword'">
                            <separator string="Keyword Matching" colspan="2" />
                            <field name="keyword" colspan="2" />
                            <p class="text-muted" colspan="2">
                                Matches if keyword appears in task name or description (case-insensitive).
                            </p>
                        </group>

                        <!-- Match Type: Project -->
                        <group invisible="match_type != 'project'">
                            <separator string="Project Matching" colspan="2" />
                            <field name="project_id" colspan="2" />
                            <p class="text-muted" colspan="2">
                                Only tasks in this project will match.
                            </p>
                        </group>

                        <!-- Match Type: Custom -->
                        <group invisible="match_type != 'custom'">
                            <separator string="Custom Domain Filter" colspan="2" />
                            <p class="text-muted" colspan="2">
                                Enter an Odoo domain filter (JSON array) to identify matching tasks.
                                Example: [["priority", "=", "3"], ["state", "!=", "done"]]
                            </p>
                            <field name="domain" colspan="2" />
                        </group>

                        <separator string="Agent Selection Strategy" />
                        <group>
                            <group>
                                <field name="assignment_strategy" />
                                <field name="require_all_capabilities" />
                            </group>
                            <group>
                                <field name="preferred_agent_id" invisible="assignment_strategy != 'preferred'" />
                                <field name="fallback_strategy" invisible="assignment_strategy != 'preferred'" />
                            </group>
                        </group>

                        <separator string="Exclusions &amp; Filters" />
                        <field name="excluded_agent_ids" widget="many2many_tags" />
                        <p class="text-muted">
                            Agents listed here will never be assigned tasks by this matcher.
                        </p>

                        <separator string="Error Information" />
                        <field name="last_error" nolabel="1" />

                        <separator string="Notes" />
                        <field name="notes" nolabel="1" />
                    </sheet>
                </form>
            </field>
        </record>

        <!-- arcvo.automation.matcher Search View -->
        <record id="arcvo_automation_matcher_search" model="ir.ui.view">
            <field name="name">Automation Matcher - Search</field>
            <field name="model">arcvo.automation.matcher</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" />
                    <field name="match_type" />
                    <field name="assignment_strategy" />
                    <separator />
                    <filter name="active" string="Active" domain="[('active', '=', True)]" />
                    <filter name="inactive" string="Inactive" domain="[('active', '=', False)]" />
                    <separator />
                    <filter name="by_tag" string="Tag-Based" domain="[('match_type', '=', 'tag')]" />
                    <filter name="by_keyword" string="Keyword-Based" domain="[('match_type', '=', 'keyword')]" />
                    <filter name="by_project" string="Project-Based" domain="[('match_type', '=', 'project')]" />
                </search>
            </field>
        </record>

        <!-- Action to view matchers -->
        <record id="arcvo_automation_matcher_action" model="ir.actions.act_window">
            <field name="name">Automation Matchers</field>
            <field name="res_model">arcvo.automation.matcher</field>
            <field name="view_mode">list,form</field>
            <field name="help">Configure rules to auto-assign tasks to agents based on tags, keywords, projects, or custom criteria.
Each matcher can assign tasks using different strategies: first available, least loaded, preferred agent, or round-robin.</field>
        </record>

        <!-- Menu item -->
        <menuitem
            id="menu_arcvo_automation_matcher"
            name="Matchers"
            parent="menu_arcvo_root"
            action="arcvo_automation_matcher_action"
            sequence="42"
        />

    </data>
</odoo>
