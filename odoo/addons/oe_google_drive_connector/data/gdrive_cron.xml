<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_gdrive_push" model="ir.cron">
            <field name="name">Google Drive: Push Attachments</field>
            <field name="model_id" ref="model_gdrive_mapping"/>
            <field name="state">code</field>
            <field name="code">model._cron_push_attachments()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

        <record id="cron_gdrive_trim_logs" model="ir.cron">
            <field name="name">Google Drive: Trim Logs</field>
            <field name="model_id" ref="model_gdrive_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_trim()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
