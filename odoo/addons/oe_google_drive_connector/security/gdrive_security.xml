<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="module_category_gdrive" model="ir.module.category">
            <field name="name">Google Drive Connector</field>
            <field name="sequence">25</field>
        </record>

        <!-- Odoo 19 groups the access levels under a res.groups.privilege. -->
        <record id="gdrive_privilege" model="res.groups.privilege">
            <field name="name">Google Drive Connector</field>
            <field name="category_id" ref="module_category_gdrive"/>
            <field name="sequence">25</field>
        </record>

        <record id="group_gdrive_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="gdrive_privilege"/>
            <field name="comment">Can push attachments to Drive and open Drive links.</field>
        </record>

        <record id="group_gdrive_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="gdrive_privilege"/>
            <field name="implied_ids" eval="[(4, ref('group_gdrive_user'))]"/>
            <field name="comment">Configures connections, rules and settings.</field>
        </record>

        <!-- System administrators are Drive managers out of the box. -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_gdrive_manager'))]"/>
        </record>

    </data>
</odoo>
