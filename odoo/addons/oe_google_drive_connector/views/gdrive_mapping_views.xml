<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="gdrive_mapping_view_list" model="ir.ui.view">
        <field name="name">gdrive.mapping.list</field>
        <field name="model">gdrive.mapping</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="model_id"/>
                <field name="connection_id"/>
                <field name="domain" widget="domain" options="{'model': 'model_name'}"/>
                <field name="model_name" column_invisible="1"/>
                <field name="auto_push"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="gdrive_mapping_view_form" model="ir.ui.view">
        <field name="name">gdrive.mapping.form</field>
        <field name="model">gdrive.mapping</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Push Sale Order files"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_id"/>
                            <field name="model_name" invisible="1"/>
                            <field name="connection_id"/>
                        </group>
                        <group>
                            <field name="auto_push"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Record Filter">
                        <field name="domain" widget="domain"
                               options="{'model': 'model_name'}" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="gdrive_mapping_action" model="ir.actions.act_window">
        <field name="name">Auto-Push Rules</field>
        <field name="res_model">gdrive.mapping</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create an auto-push rule</p>
            <p>Pick an Odoo model; the scheduled job will push new attachments of
               matching records to the chosen Drive connection.</p>
        </field>
    </record>

</odoo>
